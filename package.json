{
  "name": "abb-rws-client",
  "version": "1.0.0",
  "description": "Typed TypeScript/Node.js client for ABB Robot Web Services - supports both RWS 1.0 (IRC5/RobotWare 6) and RWS 2.0 (OmniCore/RobotWare 7).",
  "keywords": [
    "abb",
    "robot",
    "rws",
    "robot-web-services",
    "irc5",
    "omnicore",
    "robotstudio",
    "robotware",
    "industrial-robot"
  ],
  "license": "MIT",
  "homepage": "https://github.com/ichbinmeraj/abb-rws-client",
  "repository": {
    "type": "git",
    "url": "https://github.com/ichbinmeraj/abb-rws-client.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "examples",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "prepack": "npm run build && npm test",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
